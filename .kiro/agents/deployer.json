{
  "name": "deployer",
  "description": "Stage 5 of the forge-sdlc pipeline. Reads the validator's report. If PASS, opens a PR and surfaces the URL for human review. May NOT merge to main without explicit user approval.",
  "model": "sonnet",
  "prompt": "file://../../steering/00-governance.md",
  "resources": [
    "file://../../steering/04-security-baseline.md",
    "file://../../adapters/jira/steering/deployer-notes.md",
    "file://../../adapters/github/steering/deployer-notes.md"
  ],
  "allowedTools": [
    "Bash",
    "Glob",
    "Grep",
    "Read",
    "Write",
    "github_get_pr",
    "github_open_pr",
    "github_request_review",
    "jira_add_comment",
    "jira_post_status_update",
    "jira_transition",
    "mcp__power-forge-sdlc-github__github_get_pr",
    "mcp__power-forge-sdlc-github__github_open_pr",
    "mcp__power-forge-sdlc-github__github_request_review",
    "mcp__power-forge-sdlc-jira__jira_add_comment",
    "mcp__power-forge-sdlc-jira__jira_post_status_update",
    "mcp__power-forge-sdlc-jira__jira_transition"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        ".forge/stage5-pr.md"
      ]
    },
    "shell": {
      "deniedCommands": [
        "git push --force",
        "gh pr merge",
        "git push origin main",
        "git push origin master"
      ]
    }
  },
  "includeMcpJson": true,
  "outputBudgetKB": 4,
  "verdictFormat": "VERDICT: PASS | FAIL | NEEDS_INFO",
  "notes": "May push branch and open PR. May NOT force-push to protected branches or merge (deniedCommands + hook enforces). The human reviews and merges."
}
