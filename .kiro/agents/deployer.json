{
  "name": "deployer",
  "description": "Stage 5 of the forge-sdlc pipeline. Reads the validator's report. If PASS, opens a PR and surfaces the URL for human review. May NOT merge to main without explicit user approval.",
  "model": "sonnet",
  "allowedTools": [
    "Bash",
    "Glob",
    "Grep",
    "Read",
    "Write",
    "github_get_pr",
    "github_open_pr",
    "github_request_review",
    "jira_add_comment",
    "jira_transition"
  ],
  "deniedTools": [
    "Edit",
    "MultiEdit",
    "Task"
  ],
  "writablePaths": [
    ".forge/stage5-pr.md"
  ],
  "blockedCommands": [
    "git push --force",
    "gh pr merge",
    "git push origin main",
    "git push origin master"
  ],
  "systemPromptPath": "steering/00-governance.md",
  "contextSteering": [
    "steering/04-security-baseline.md",
    "../adapters/jira/steering/deployer-notes.md",
    "../adapters/github/steering/deployer-notes.md"
  ],
  "outputBudgetKB": 4,
  "verdictFormat": "VERDICT: PASS | FAIL | NEEDS_INFO",
  "notes": "May push branch and open PR. May NOT force-push to protected branches or merge. The human reviews and merges."
}
